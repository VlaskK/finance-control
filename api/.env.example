# Скопируйте в api/.env и заполните значения.

# Подключение к Postgres (по умолчанию — локальный контейнер из docker-compose.yml).
DATABASE_URL=postgres://finflow:finflow@localhost:5432/finflow

# Токен Telegram-бота от @BotFather. Если пусто — бот не запускается, API работает как обычно.
BOT_TOKEN=

# Кому разрешён доступ к боту — Telegram ID через запятую (узнать свой: напишите боту /whoami).
ALLOWED_TELEGRAM_IDS=
